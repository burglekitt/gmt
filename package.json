{
  "name": "root",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24 <25"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "nx": "nx",
    "graph": "nx graph",
    "sync": "nx sync",
    "sync:check": "nx sync:check",
    "reset": "nx reset",
    "build": "nx run-many -t build",
    "test:nx": "nx run-many -t test",
    "lint:nx": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "validate": "nx run-many -t lint test typecheck build",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "affected:typecheck": "nx affected -t typecheck",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "test": "vitest run",
    "test:gmt": "vitest run --config packages/gmt/vitest.config.ts",
    "test:gmt:watch": "vitest --config packages/gmt/vitest.config.ts",
    "test:gmt-oxlint": "vitest run --config packages/gmt-oxlint/vitest.config.ts",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release:publish": "pnpm run validate && pnpm run changeset:publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@changesets/cli": "^2.30.0",
    "@nx/js": "^22.5.4",
    "@tanstack/intent": "^0.0.29",
    "@types/node": "^22.13.10",
    "full-icu": "^1.3.1",
    "nx": "^22.5.4",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  }
}
