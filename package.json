{
  "name": "burglekitt",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "nx": "nx",
    "graph": "nx graph",
    "sync": "nx sync",
    "sync:check": "nx sync:check",
    "reset": "nx reset",
    "build": "nx run-many -t build",
    "test:nx": "nx run-many -t test",
    "lint:nx": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "validate": "nx run-many -t lint test typecheck build",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "affected:typecheck": "nx affected -t typecheck",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "test": "vitest run",
    "test:gmt": "cd packages/gmt && vitest run",
    "test:gmt:watch": "cd packages/gmt && vitest"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1"
  },
  "devDependencies": {
    "@nx/js": "^22.5.4",
    "@types/bun": "^1.3.10",
    "@biomejs/biome": "^1.7.3",
    "nx": "^22.5.4",
    "vitest": "^2.0.5",
    "zod": "^3.23.8"
  }
}
