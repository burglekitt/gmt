{
  "name": "@burglekitt/gmt-eslint",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared ESLint configuration for gmt projects",
  "license": "MIT",
  "contributors": [
    {
      "name": "Baldur Páll Hólmgeirsson",
      "url": "https://github.com/baldurpan"
    },
    {
      "name": "Craig O. Curtis",
      "url": "https://github.com/craig-o-curtis"
    }
  ],
  "main": "./eslint/index.mjs",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "tanstack-intent"
  ],
  "files": [
    "eslint",
    "LICENSE",
    "README.md",
    "skills"
  ],
  "scripts": {
    "pack": "npm pack --dry-run",
    "publish:dry-run": "npm publish --access public --dry-run",
    "publish:public": "npm publish --access public"
  },
  "exports": {
    ".": "./eslint/index.mjs"
  },
  "devDependencies": {
    "@tanstack/intent": "^0.0.29"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  }
}
