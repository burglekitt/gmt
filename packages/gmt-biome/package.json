{
  "name": "@burglekitt/gmt-biome",
  "version": "0.0.1",
  "private": false,
  "description": "Shared Biome configuration for gmt projects",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "biome.json",
    "plugins",
    "README.md"
