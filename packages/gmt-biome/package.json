{
  "name": "@burglekitt/gmt-biome",
  "version": "1.0.1",
  "private": false,
  "description": "Shared Biome configuration for gmt projects",
  "license": "MIT",
  "contributors": [
    {
      "name": "Baldur Páll Hólmgeirsson",
      "url": "https://github.com/baldurpan"
    },
    {
      "name": "Craig O. Curtis",
      "url": "https://github.com/craig-o-curtis"
    }
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "biome",
    "biome-plugin",
    "temporal",
    "date",
    "lint",
    "tanstack-intent"
  ],
  "files": [
    "biome.json",
    "plugins",
    "LICENSE",
    "README.md",
    "skills"
  ],
  "scripts": {
    "pack": "npm pack --dry-run",
    "publish:dry-run": "npm publish --access public --dry-run",
    "publish:public": "npm publish --access public"
  },
  "exports": {
    ".": "./biome.json",
    "./plugins/no-new-date": "./plugins/no-new-date.grit",
    "./plugins/no-new-date.grit": "./plugins/no-new-date.grit",
    "./plugins/no-date-now": "./plugins/no-date-now.grit",
    "./plugins/no-date-now.grit": "./plugins/no-date-now.grit",
    "./plugins/no-date-parse": "./plugins/no-date-parse.grit",
    "./plugins/no-date-parse.grit": "./plugins/no-date-parse.grit",
    "./plugins/no-date-utc": "./plugins/no-date-utc.grit",
    "./plugins/no-date-utc.grit": "./plugins/no-date-utc.grit",
    "./plugins/no-date-getTimezoneOffset": "./plugins/no-date-getTimezoneOffset.grit",
    "./plugins/no-date-getTimezoneOffset.grit": "./plugins/no-date-getTimezoneOffset.grit"
  },
  "devDependencies": {
    "@tanstack/intent": "^0.0.29"
  },
  "peerDependencies": {
    "@biomejs/biome": ">=2.0.0"
  }
}
