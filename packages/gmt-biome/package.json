{
  "name": "@burglekitt/gmt-biome",
  "version": "1.0.0",
  "private": false,
  "description": "Shared Biome configuration for gmt projects",
  "license": "MIT",
  "contributors": [
    {
      "name": "Baldur Páll Hólmgeirsson",
      "url": "https://github.com/baldurpan"
    },
    {
      "name": "Craig O. Curtis",
      "url": "https://github.com/craig-o-curtis"
    }
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "biome",
    "biome-plugin",
    "temporal",
    "date",
    "lint",
    "tanstack-intent"
  ],
  "files": [
    "recommended.json",
    "plugins",
    "LICENSE",
    "README.md",
    "skills"
  ],
  "scripts": {
    "pack": "npm pack --dry-run",
    "publish:dry-run": "npm publish --access public --dry-run",
    "publish:public": "npm publish --access public"
  },
  "exports": {
    ".": "./recommended.json",
    "./plugins/*.grit": "./plugins/*.grit",
    "./plugins/*": "./plugins/*.grit"
  },
  "devDependencies": {
    "@tanstack/intent": "^0.0.29"
  },
  "peerDependencies": {
    "@biomejs/biome": ">=2.0.0"
  }
}
