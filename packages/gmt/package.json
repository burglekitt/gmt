{
  "name": "@burglekitt/gmt",
  "version": "0.0.1",
  "type": "module",
  "description": "Temporal-based date and time utilities with timezone support and polyfill integration",
  "license": "MIT",
  "author": "Burglekitt <https://github.com/burglekitt>",
  "repository": {
    "type": "git",
    "url": "https://github.com/burglekitt/gmt.git",
    "directory": "packages/gmt"
  },
  "bugs": {
    "url": "https://github.com/burglekitt/gmt/issues"
  },
  "homepage": "https://github.com/burglekitt/gmt#readme",
  "keywords": ["temporal", "timezone", "date", "time", "datetime", "polyfill"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": ["dist", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "build:types": "tsc --project tsconfig.build.json --declaration --emitDeclarationOnly",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0",
    "vitest": "^2.0.5"
  }
}
